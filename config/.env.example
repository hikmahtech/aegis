# AEGIS bootstrap config — copy to config/.env and fill in.
#
#   cp config/.env.example config/.env
#
# This file holds ONLY the handful of values needed to boot. Everything else
# (LLM provider + key, Slack/Todoist/GitHub/Sentry/… integrations, infra
# hosts, coding agents) is configured from the admin panel and stored
# encrypted in the DB — do NOT list those here. All keys take the AEGIS_
# prefix (pydantic-settings). Never commit the real config/.env.

# --- Required: admin login for the panel at http://localhost:8080 ---
# admin/admin is rejected at boot — pick your own.
AEGIS_ADMIN_USERNAME=admin
AEGIS_ADMIN_PASSWORD=change-me

# --- Strongly recommended: app secret ---
# Fernet key that encrypts integration secrets stored in the DB. Unset = those
# secrets are stored in plaintext. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AEGIS_SECRET_KEY=

# --- Optional: local Postgres password (compose interpolation) ---
# Read by docker-compose.yml for the bundled Postgres; defaults to aegis_dev.
# This one lives in a ROOT-level .env (not this file) or your shell env.
# POSTGRES_PASSWORD=aegis_dev

# --- Optional: LLM backend env fallback ---
# Preferred path is the admin "Models & Providers" page. These are only used
# until you configure a provider there (or for local dev).
# AEGIS_LITELLM_URL=http://litellm:4000
# AEGIS_LITELLM_API_KEY=

# --- Optional: Slack (only with `docker compose --profile slack up`) ---
# Preferred path is admin → Configure → Slack (encrypted in DB). Env is dev fallback.
# AEGIS_CHANNEL=slack
# AEGIS_SLACK_BOT_TOKEN=
# AEGIS_SLACK_APP_TOKEN=

# --- Optional: infra-alert cluster label ---
# Alerts whose Prometheus/Alertmanager `cluster` label equals this are routed
# straight to infra-gitops (skipping the LLM repo-match). Blank ⇒ off; alerts
# are still classified as infra by alertname. Set to your own cluster label.
# AEGIS_INFRA_CLUSTER=

# --- Optional: script-host k8s contexts (ArgoCD chat tools + Live Inspector) ---
# Comma-separated k8s "context" names that exist on the remote script host
# (the host scripts/infra/*.sh + the argocd CLI run on). Blank ⇒ none; k8s
# pod/deployment/log tools then resolve only via registered kind=k8s infra
# entries (by slug), and the ArgoCD tools have no valid context until set.
# AEGIS_SCRIPT_HOST_K8S_CONTEXTS=

# --- Optional: Money Hygiene (Maou) currency ---
# Currency all Money-Hygiene charges normalize to; drives the digest symbol.
# Defaults to INR (the author's own setup). Set matching fx rates below if
# you change this.
# AEGIS_HOME_CURRENCY=
# Deterministic bank-alert guard — comma-separated bank alert-sender domains
# whose mail must never be minted into a recurring charge (belt-and-suspenders
# behind the LLM prompt hardening). Blank ⇒ guard is a no-op.
# AEGIS_BANK_ALERT_SENDERS=
# Fallback FX rates (foreign currency -> home currency) as a JSON object,
# e.g. {"USD": 84.5, "EUR": 92.0}. Defaults to the built-in INR rates.
# AEGIS_MONEY_HYGIENE_FX_RATES=

# --- Optional: admin SPA dist path override ---
# Where Core looks for the built admin-panel frontend (index.html) when the
# Docker/local-dev default locations don't apply. Blank ⇒ Core tries
# /app/admin-panel/frontend/dist, then the repo-relative path, then CWD.
# AEGIS_ADMIN_DIST_DIR=

# --- Optional: personality starter-files dir override ---
# Where personalities/<agent>/*.md starter files are imported from on first
# boot (DB rows win afterwards). Blank ⇒ repo's personalities/ dir, then
# /app/personalities in the container.
# AEGIS_PERSONALITY_DIR=

# --- Optional: OpenTelemetry ---
# Opt-in tracing/logging correlation across core/worker/comms; no-op unless
# explicitly enabled.
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=aegis-core
